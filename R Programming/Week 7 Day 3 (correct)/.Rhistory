# Unlike many other programming languages, you can ouput code in R without using a print function.
# However, R does have a print() function available if you want to use it.
#There are times you must use the print() fucntion to output code, for example when working with for loops.
# Example
for(x in 1:10) {
print(x)
}
# Conclusion: It is up to you whether you want to use the print() function to output code. However, when your code is inside an R expression (e.g. inside curly braces {} like in the example above), use the print() function to output the result.
# Variable: Used in storing values. It takes that character immediately.
# variable takes the "<-"
#Example
name <- "Abass"
age <- 40
name
age
name <- Abass
names <- Soji
name
names <- "soji"
name
names
# from the example, names and age are variables while Abass and 40 are values.
name <- "Teacher"
name
print(name)
print(names)
# string
name <- "Abass Akinsanya"
# number
rank <- 1
# number
marks <- 96
# float
points <- 125.40
print(name)
print(rank)
print(marks)
print(points)
marks
print(age)
# R Concatenate Elements
# You can also concantenate or join two or more elements, by using the paste() function
# To combine both text and a variable, R uses comma (,)
# Example
text <- Annoying
text <- "Wahalalicious"
print("R is", text)
paste("R is", text)
# You use paste when joining or concantenating
# Combining two variables together using the paste function
#Example
text 1 <- "R is"
text 2 <- "awesome"
paste(text 1, text 2)
text_1 <- "R is"
text_2 <- "wahalalicious"
paste(text_1, text_2)
