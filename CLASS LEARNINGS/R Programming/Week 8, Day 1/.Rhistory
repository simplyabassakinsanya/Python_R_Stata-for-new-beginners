# The result of the variables will always come out in a string function.
# In R, variables do not need to be declared with any particular type, and can even change type after they have been set.
my_var <- 30
my_var <- "Sally" # my_var is now type character (aka string)
print(my_var)
# Basic Data types in R can be divided into the following types.
# numeric - (10.5, 55, 787)
# integer - (1L, 55L, 100L, where the letters 'L' declares this as an integer)
# complex - (9 + 3), where "i" is the imaginary part)
# Character (a.k.a string) - ("k", "R is exciting", "False", "11.5")
# complex - (9 + 3), where "i" is the imaginary part)
# complex - (9 + 3i), where "i" is the imaginary part)
# logical (a.k.a boolean) - (True or False)
# We can use the class() function to check the data type of a variable.
# numeric
x <- 10.5
class(x)
# Integer
x <- 100L
# L must be in capital letter
class(x)
# complex
z <- 9i + 3
class(z)
# character
d <- "R is exciting"
class(d)
# Logical
x <- TRUE # This must be in capital letter to differentiate it from a string
class(x)
# Numeric data type in R
# The numeric data type stores numbers, decimal numbers, etc. for example
marks <- 99
points <- 125.50
print(marks)
points
class(marks)
class(points)
sheets <- 33.5
class(sheets)
know <- 240.32L
know <- 240L
class(know)
now <- -100
class(now)
# AN integer is declared by an appended letter "L"
s <- 3 + ti
s
s <- ti + 3
a <- 7 + 3i
a
class(a)
name_one <- "Amit" # use a single quote or double quote while creating a character or string type.
name_one
class(name_amit)
class(name_one)
passed <- TRUE
failed <- FALSE
passed
failed
class(passed)
class(failed)
# logical is the same as # boolean (bool in python)
names <- c("Abass", "Soji", "Lekan", "Temitope")
print(names)
class(names)
names
# Vector of "characters" are the results, so it is still a vector.
#List in R
my_list <- list("Abass", c(1985, 41), 2, 1.5)
my_list
print(my_list)
class(my_list)
# COnverting from one R number to another.
x <- 1L # Integer
y <- 2 # Numeric
a <- as.numeric(x)
a
b <- as.integer(y)
b
class (a)
class(b)
c <- as.complex(x)
c
class(c)
d <- as.complex(y)
d
class(d)
