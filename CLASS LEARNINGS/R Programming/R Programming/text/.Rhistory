b <- 33
c <- 500
if (a > b | a > c) {
print("at least, one of the conditions is true")
}
score <- 75
if (score >= 90) {
print("Grade A")
} else if (score >= 70) {
print("Grade B")
} else if (score >= 50) {
print("Grade C")
} else {
print("Fail")
}
